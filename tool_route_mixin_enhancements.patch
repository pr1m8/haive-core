+        import hashlib
+        import json
+        
+        # Create a deterministic representation of the graph state
+        state_repr = {
+            "nodes": sorted(self.nodes.keys()),
+            "edges": sorted([f"{s}->{t}" for s, t in self.edges]),
+            "branches": sorted(self.branches.keys()),
+            "entry_points": sorted(self.entry_points),
